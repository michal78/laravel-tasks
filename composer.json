{
    "name": "michal78/laravel-tasks",
    "description": "Scheduled model tasks for Laravel",
    "keywords": [
        "michal78",
        "laravel-tasks"
    ],
    "homepage": "https://github.com/michal78/laravel-tasks",
    "license": "MIT",
    "type": "library",
    "version": "1.0.0.3",
    "authors": [
        {
            "name": "Michal Skogemann",
            "email": "michal.skogemann@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Michal78\\Tasks\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Michal78\\Tasks\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"

    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Michal78\\Tasks\\TasksServiceProvider"
            ],
            "aliases": {
                "Tasks": "Michal78\\Tasks\\TasksFacade"
            }
        },
        "minimum-stability": "dev",
        "prefer-stable": true
    }
}
